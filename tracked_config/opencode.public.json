{
  "theme": "vercel",
  "autoupdate": true,
  "small_model": "openai/gpt-5.4-mini",
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai",
      "name": "codexzh",
      "options": {
        "baseURL": "https://api.codexzh.com/v1",
        "apiKey": "",
        "setCachekey": true,
        "options": {
          "reasoningEffort": "high",
          "textVerbosity": "low",
          "reasoningSummary": "auto"
        }
      },
      "models": {
        "gpt-5.4": {
          "name": "gpt-5.4"
        },
        "gpt-5.4-mini": {
          "name": "gpt-5.4-mini"
        },
        "gpt-5.3-codex": {
          "name": "gpt-5.3-codex"
        }
      }
    }
  }
}
